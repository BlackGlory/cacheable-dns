    "brave-json": "^0.2.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "extra-abort": "^0.4.1",
    "extra-disk-cache": "^0.13.0",
    "extra-dns": "^0.1.8",
    "extra-filesystem": "^0.6.2",
    "extra-logger": "^0.8.0",
    "extra-memoize": "^0.10.1",
    "extra-promise": "^7.1.1",
    "extra-rand": "^0.5.1",
    "extra-utils": "^6.0.0"
  }
